  "objective": "Implement the first local RevDeck plugin SDK preview: manifest validation, stable ObjectBatch dry-run schemas, plugin execution safety skeleton, CLI plugin commands, and minimal conformance tests.",
  "scope": {
    "must_have": [
      "revdeck-plugin.toml manifest structs and validation",
      "ObjectBatch graph delta schemas and dry-run validation",
      "default-deny permission model and sanitized diagnostics",
      "plugin run audit table or equivalent host-owned run record",
      "revdeck plugin validate|inspect|test CLI commands",
      "tests/plugin-sdk fixtures and golden contract tests"
    ],
    "non_goals": [
      "public plugin marketplace",
      "real OS sandbox hardening beyond safety skeleton",
      "custom TUI plugin renderers",
      "plugin direct SQLite access",
      "full ObjectBatch commit of plugin data unless dry-run foundation is complete"
    ]
